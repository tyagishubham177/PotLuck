{
  "name": "@potluck/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./web": {
      "types": "./src/web.ts",
      "import": "./src/web.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "tsup src/index.ts src/server.ts src/web.ts --format esm,cjs --clean",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}
