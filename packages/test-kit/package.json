{
  "name": "@potluck/test-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "dependencies": {
    "@potluck/contracts": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
